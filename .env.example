# Get keys from https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# In Clerk Dashboard → Users → select user → Public metadata:
# { "role": "admin" }

# --- Signup email notifications (server) ---
# Clerk Dashboard → Webhooks → Add endpoint
# URL: https://YOUR-APP.herokuapp.com/api/webhooks/clerk
# Events: user.created
CLERK_WEBHOOK_SECRET=whsec_...

# Where signup alerts are sent (defaults to docsobers@mac.com)
NOTIFY_TO=docsobers@mac.com

# SMTP (e.g. Gmail app password, SendGrid, Mailgun)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your_app_password
NOTIFY_FROM=you@example.com
